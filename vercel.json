{
  "crons": [
    {
      "path": "/api/fetch-market-prices",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/update-prices",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/update-news",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/send-alerts",
      "schedule": "0 */6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path((?!cron/).*)",
      "destination": "https://xoegapeodtbncirqvlmi.supabase.co/functions/v1/:path"
    },
    {
      "source": "/api/cron/update-prices",
      "destination": "/api/cron/update-prices"
    },
    {
      "source": "/api/cron/update-news",
      "destination": "/api/cron/update-news"
    },
    {
      "source": "/api/cron/send-alerts",
      "destination": "/api/cron/send-alerts"
    },
    {
      "source": "/api/:path*",
      "destination": "https://xoegapeodtbncirqvlmi.supabase.co/functions/v1/:path*"
    }
  ]
}
